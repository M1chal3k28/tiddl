{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "inputs": [
        {
            "id": "programArgs",
            "type": "promptString",
            "description": "Podaj argumenty programu"
        }
    ],
    "configurations": [
        {
            "name": "tiddl refresh token",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\Scripts\\tiddl.exe",
            "args": [
                "auth",
                "refresh"
            ],
            "console": "externalTerminal",
            "justMyCode": false,
        },
        {
            "name": "download ",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\Scripts\\tiddl.exe",
            "args": [
                "download",
                "-q",
                "max",
                "url",
                "${input:programArgs}"
            ],
            "console": "externalTerminal",
            "justMyCode": false,
        }
    ]
}